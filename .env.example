# Supabase — Tribes data/auth project (pnlknurdxcduhbtxdefl)
# Get real values from the Supabase dashboard: Project Settings → API
# Copy this file to .env.local and fill in the values.

# Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key — safe to expose to the browser, respects RLS
# Use the modern sb_publishable_... format for new applications
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER-ONLY, BYPASSES RLS
# Never commit. Never prefix with NEXT_PUBLIC_. Never import from a client component.
# Only used inside src/lib/supabase/admin.ts, gated by requireAdmin().
SUPABASE_SERVICE_ROLE_KEY=
